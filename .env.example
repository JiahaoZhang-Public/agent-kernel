# Agent OS Kernel — Environment Variables
#
# Copy this file to .env and fill in the values you need.
# Only required for examples that use LLM providers (03_agent_loop, etc.)

# LLM API Key (required for agent loop examples)
# Supports any provider via LiteLLM: OpenAI, Anthropic, Azure, etc.
OPENAI_API_KEY=sk-your-key-here

# Optional: Override the default model (default: gpt-4o-mini)
# AGENT_MODEL=gpt-4o-mini

# Optional: Custom API base URL
# AGENT_API_BASE=https://api.openai.com/v1
